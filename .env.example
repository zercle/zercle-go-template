# Application
APP_ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zercle_chat
DB_USER=zercle_ch=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

# Valkey (Redis alternative)
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_DB=0

# JWT Authentication
JWT_SECRET=your-256-bit-secret-key-here-minimum-32-chars
JWT_EXPIRY=24h
REFRESH_EXPIRY=168h

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
