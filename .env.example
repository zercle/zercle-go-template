# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GRPC_HOST=0.0.0.0
GRPC_PORT=9090

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zercle_chat
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_MAX_CONNS=10
DB_MAX_IDLE_CONNS=5

# Cache (Valkey/Redis) Configuration
CACHE_HOST=localhost
CACHE_PORT=6379
CACHE_PASSWORD=
CACHE_DB=0

# Authentication
AUTH_ACCESS_TOKEN_SECRET=your-256-bit-secret-key-here-minimum-32-chars
AUTH_REFRESH_TOKEN_SECRET=another-256-bit-secret-key-here-minimum-32-chars
AUTH_ACCESS_TOKEN_TTL=24h
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_ISSUER=zercle-go-template

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Metrics
METRICS_ENABLED=false
METRICS_PORT=9090

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
TRACING_ENDPOINT=
OTEL_SERVICE_NAME=zercle-go-template

# Application
APP_ENVIRONMENT=development