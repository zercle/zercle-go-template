# App
APP_NAME=zercle-go-template
APP_ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_SHUTDOWN_TIMEOUT=15s

# HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_BODY_LIMIT=1M
HTTP_CORS_ALLOW_ORIGINS=*
HTTP_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
HTTP_CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

# gRPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# DB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_MAX_CONNS=10
DB_MAX_IDLE_CONNS=2
DB_MAX_CONN_IDLE=30m
DB_MAX_CONN_LIFE=1h
DB_CONNECT_TIMEOUT=5s

# Valkey
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_DB=0

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# OTel
OTEL_EXPORTER=none
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=zercle-go-template
OTEL_TRACES_SAMPLER_ARG=1.0

# Stub feature
EXAMPLE_ENABLED=true
